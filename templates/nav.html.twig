
{% if is_granted('ROLE_USER') %}
    {% set roles = app.user.roles|default([]) %}

    {% if is_granted('IS_IMPERSONATOR') %}
        {% set roles = roles|merge(['ROLE_IMPERSONATOR']) %}
    {% endif %}
{% else %}
    {% set roles = [] %}
{% endif %}

{% cache cache_key('nav', [roles|join(','), route]) %}

    <nav class="sidebar" id="sidebar-nav">
        <header>
            <a class="brand" href="{{ path('home') }}">
                <img src="{{ asset('build/logo-small.png') }}" width="20" height="20" alt="" />
                {{ 'app.name'|trans }}
            </a>
        </header>

        {% set navItems = [
            { route: 'files_listFiles', activePrefix: 'files_', icon: 'directory', label: 'nav.files' },
            { route: 'listTorrents', activePrefix: 'torrents_', icon: 'torrents', label: 'nav.torrents' },
            { route: 'showSearch', activePrefix: 'search_', icon: 'search', label: 'nav.search' },
            { route: 'listSharings', activePrefix: 'sharings_', icon: 'link', label: 'nav.sharings' },
        ] %}

        {% if is_granted('ROLE_ADMIN') %}
            {% set navItems = navItems|merge([
                { route: 'listUsers', activePrefix: 'users_', icon: 'users', label: 'nav.users' },
            ]) %}
        {% endif %}

        <ul>
            {% set currentPrefix = app.request.attributes.get('_prefixId') %}
            {% for item in navItems %}
                <li>
                    <a class="button {% if currentPrefix === item.activePrefix %}active{% endif %}" href="{{ path(item.route) }}">{{ ux_icon(item.icon) }}{{ item.label|trans }}</a>
                </li>
            {% endfor %}
        </ul>

        <footer>
            <a href="{{ path('editAccount') }}" class="button account-button">
                <span class="user-icon">{{ ux_icon('user') }}</span>
                {{ 'nav.account'|trans }}
            </a>

            {% if is_granted('IS_IMPERSONATOR') %}
                <a href="{{ impersonation_exit_path() }}" class="button icon-only exit-impersonation-button" title="{{ 'nav.exit'|trans }}">
                    {{ ux_icon('sign-out') }}
                </a>
            {% else %}
                <a href="{{ path('_logout_main') }}" class="button icon-only logout-button" title="{{ 'nav.logout'|trans }}">
                    {{ ux_icon('sign-out') }}
                </a>
            {% endif %}
        </footer>
    </nav>
{% endcache %}
