{% extends 'skeleton.html.twig' %}

{% block title %}{{ 'app.name'|trans }} - {{ 'login.title'|trans }}{% endblock %}

{% block content %}
    {% if error is defined and error is not empty %}
        <div class="alert alert-danger" role="alert">{{ error|trans }}</div>
    {% endif %}

    <div class="form-box">
        <h1>{{ 'login.title'|trans }}</h1>
        {{ form(form) }}
    </div>
{% endblock %}
