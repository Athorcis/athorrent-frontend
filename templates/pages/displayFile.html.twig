{% extends 'pages/fileDetails.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('media') }}
{% endblock %}

{% block content %}
    {{ parent() }}

    {% if text is defined %}
        <pre>{{ text }}</pre>
    {% elseif src is defined %}
        <img class="content" src="{{ path('openFile', { path: src }) }}" />
    {% endif %}
{% endblock %}
